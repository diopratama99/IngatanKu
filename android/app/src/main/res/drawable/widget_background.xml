<?xml version="1.0" encoding="utf-8"?>
<!--
  Editorial dark canvas for the Recent Notes widget.

  Notes:
   * #0F172A solid fill (matches AppColors.bgPrimary).
   * Radius 24dp — close to the Android 12+ system-applied rounded mask
     (~28dp on most launchers) so the corners don't reveal a square edge
     just inside the system mask.
   * No stroke: the system rounding clips a stroke into a half-arc that
     looks broken. We rely on the contrast between the navy fill and the
     wallpaper to give the tile its definition.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#0F172A"/>
    <corners android:radius="24dp"/>
</shape>
